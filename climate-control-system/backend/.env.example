NODE_ENV=development
PORT=3306
APP_URL=http://localhost:5173

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=SmartClimateControl
DB_USERNAME=root
DB_PASSWORD=

JWT_ACCESS_SECRET=replace_me_access_secret
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

SOCKET_CORS_ORIGIN=http://localhost:5173
API_CORS_ORIGIN=http://localhost:5173

API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=180
IOT_RATE_LIMIT_WINDOW_MS=60000
IOT_RATE_LIMIT_MAX=240

SENSOR_TEMP_ALERT_MAX=30
SENSOR_HUMIDITY_ALERT_MIN=35

LOG_LEVEL=info

MQTT_ENABLED=true
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=climate_mqtt
MQTT_PASSWORD=climate_mqtt_password
